# Ambiente (development | production)
NODE_ENV=development

# Servidor
PORT=3001

# Timezone (afeta dashboard "hoje/ontem")
TZ=America/Recife

# JWT
JWT_SECRET=troque-por-algo-aleatorio-longo-minimo-32-chars
JWT_EXPIRES_IN=7d

# CORS - URL do frontend (separar por vírgula para múltiplas)
CORS_ORIGIN=http://localhost:5173,http://localhost:4173
